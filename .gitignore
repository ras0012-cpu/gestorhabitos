# ─────────────────────────────────────────────
# .gitignore — backend
# ─────────────────────────────────────────────

# Dependencias — se reinstalan con "npm install"
node_modules/

# Variables de entorno — contienen secretos, NUNCA a Git
.env

# Base de datos SQLite — datos de usuarios reales
*.db
*.db-journal
*.sqlite
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*

# Sistema operativo
.DS_Store
Thumbs.db

# Editores
.vscode/
.idea/
*.swp
*.swo